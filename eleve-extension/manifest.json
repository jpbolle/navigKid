{
  "manifest_version": 3,
  "name": "NavigKid!",
  "version": "1.1",
  "description": "Extension de recherche guidée par IA pour les élèves",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "background": {
    "service_worker": "background/index.js"
  },
  "side_panel": {
    "default_path": "sidebar/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/index.js"],
      "css": ["content/style.css"]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "Ouvrir NavigKid!"
  }
}
